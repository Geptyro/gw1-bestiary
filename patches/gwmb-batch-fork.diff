+// Single-pass model<->animation index dump. For every FFNA_Type2 file, records
+// the signature words of each known chunk header:
+//   BB9/FA1 chunks = animation side, FA0/BB8 chunks = geometry side.
+// Offline join: a model is animated iff some file carries a BB9/FA1 chunk with
+// the same (hash0, hash1) pair as the model's geometry chunk.
+inline void dump(const std::wstring& out_csv, DATManager* dat_manager)
+{
+    const std::filesystem::path csv_path(out_csv);
+    std::ofstream csv(csv_path);
+    csv << "chunk,file_hash,hash0,hash1,rigged\n";
+    const auto& mft = dat_manager->get_MFT();
+    int files = 0;
+    for (size_t i = 0; i < mft.size(); ++i)
+    {
+        if (mft[i].type != FFNA_Type2)
+            continue;
+        unsigned char* data = dat_manager->read_file(static_cast<int>(i));
+        if (!data)
+            continue;
+        const size_t data_size = mft[i].uncompressedSize;
+        if (data_size >= 5 + 8 && data[0] == 'f' && data[1] == 'f' && data[2] == 'n' && data[3] == 'a')
+        {
+            size_t offset = 5;
+            while (offset + 8 <= data_size)
+            {
+                uint32_t chunk_id, chunk_size;
+                std::memcpy(&chunk_id, &data[offset], sizeof(uint32_t));
+                std::memcpy(&chunk_size, &data[offset + 4], sizeof(uint32_t));
+                if (chunk_id == 0 || chunk_size == 0)
+                    break;
+                const size_t cdo = offset + 8;
+                if (cdo + chunk_size > data_size)
+                    break;
+                const char* kind = nullptr;
+                uint32_t h0 = 0, h1 = 0;
+                if (chunk_id == GW::Parsers::CHUNK_ID_BB9 || chunk_id == GW::Parsers::CHUNK_ID_BB8)
+                {
+                    if (cdo + sizeof(GW::Parsers::BB9Header) <= data_size)
+                    {
+                        GW::Parsers::BB9Header header;
+                        std::memcpy(&header, &data[cdo], sizeof(header));
+                        h0 = header.modelHash0;
+                        h1 = header.modelHash1;
+                        kind = chunk_id == GW::Parsers::CHUNK_ID_BB9 ? "BB9" : "BB8";
+                    }
+                }
+                else if (chunk_id == GW::Parsers::CHUNK_ID_FA1 || chunk_id == GW::Parsers::CHUNK_ID_FA0)
+                {
+                    if (cdo + sizeof(GW::Parsers::FA1Header) <= data_size)
+                    {
+                        GW::Parsers::FA1Header header;
+                        std::memcpy(&header, &data[cdo], sizeof(header));
+                        h0 = header.boundingBoxId;
+                        h1 = header.collisionMeshId;
+                        kind = chunk_id == GW::Parsers::CHUNK_ID_FA1 ? "FA1" : "FA0";
+                    }
+                }
+                if (kind)
+                    csv << kind << ',' << std::format("{:X}", mft[i].Hash) << ','
+                        << h0 << ',' << h1 << ",\n";
+                offset += 8 + chunk_size;
+            }
+        }
+        delete[] data;
+
+        // Model-side signature requires the real geometry parse: header reads on
+        // FA0/BB8 geometry chunks yield shared garbage, not per-model signatures.
+        try
+        {
+            auto model_file = dat_manager->parse_ffna_model_file(static_cast<int>(i));
+            if (model_file.parsed_correctly && !model_file.geometry_chunk.models.empty())
+            {
+                bool rigged = false;
+                for (const auto& gm : model_file.geometry_chunk.models)
+                {
+                    if (!gm.extra_data.empty() ||
+                        (!gm.vertices.empty() && gm.vertices[0].has_group))
+                    {
+                        rigged = true;
+                        break;
+                    }
+                }
+                csv << "MODEL," << std::format("{:X}", mft[i].Hash) << ','
+                    << model_file.geometry_chunk.sub_1.f0xC << ','
+                    << model_file.geometry_chunk.sub_1.f0x10 << ','
+                    << (rigged ? 1 : 0) << '\n';
+            }
+        }
+        catch (...)
+        {
+        }
+        files++;
+    }
+    csv << "# scanned " << files << " type2 files\n";
+}
